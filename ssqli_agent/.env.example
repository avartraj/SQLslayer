# Copy this file to .env and fill in the key(s) for the provider you use.
#
# Pick a provider (see `python main.py --list-models` for all of them):
#   groq | anthropic | openai | openrouter | together   (cloud, need a key)
#   ollama | lmstudio | llamacpp | custom               (local, no key)
LLM_PROVIDER=groq

# Optional: override the model and/or endpoint for the active provider
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_BASE_URL=http://localhost:11434/v1/chat/completions

# ── Cloud API keys (set only the one you use) ────────────────────────────────
GROQ_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# TOGETHER_API_KEY=

# ── Local models need NO key ─────────────────────────────────────────────────
#   Ollama:    ollama serve   &&   ollama pull llama3.1
#              LLM_PROVIDER=ollama   LLM_MODEL=llama3.1
#   LM Studio: start its local server, then LLM_PROVIDER=lmstudio
